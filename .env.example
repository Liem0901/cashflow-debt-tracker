# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cashflow?retryWrites=true&w=majority

# Firebase — client (Vite exposes VITE_* to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase — server (Vercel env vars, never commit)
# Option A: paste full service account JSON as one line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Option B: separate fields from service account JSON
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Legacy fallback when Firebase auth is not configured
DEFAULT_USER_ID=default-user
